# Database
POSTGRES_USER=agent
POSTGRES_PASSWORD=agentpass
POSTGRES_DB=agentdb
DATABASE_URL=postgresql+asyncpg://agent:agentpass@postgres:5432/agentdb

# Redis / Celery
# REDIS_URL is used by the API health-check; CELERY_BROKER_URL/RESULT_BACKEND are used by the worker.
# Keep all three pointing at the same Redis instance unless you split them intentionally.
# Production: include the Redis password → redis://:PASSWORD@redis:6379/0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Redis password — leave empty for local dev; required in production (set by gen-env.sh)
REDIS_PASSWORD=

# LLM — provider-agnostic via OpenAI-compatible API.
# Leave OPENAI_API_KEY as sk-not-set to use the built-in MockPlanner (no API calls, no cost).
#
# OpenAI (default — OPENAI_BASE_URL can be omitted entirely):
OPENAI_API_KEY=sk-not-set
# OPENAI_BASE_URL=             # omit or leave blank → SDK default (api.openai.com/v1)
OPENAI_MODEL=gpt-4o-mini
#
# ── DeepSeek example ──────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # your DeepSeek key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
#
# ── Moonshot example ──────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # your Moonshot key
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=moonshot-v1-8k
#
# ── OpenRouter example ────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini
#
# ── ZhipuAI (GLM) — synthesis only; takes priority over OpenAI when set ──────
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx
# ZHIPU_MODEL=glm-4-flash        # default; other options: glm-4, glm-4-air

# Search — Tavily is the primary provider when TAVILY_API_KEY is set.
# DuckDuckGo is used automatically as a fallback (no key needed).
# Get a free key at https://tavily.com
TAVILY_API_KEY=                  # leave blank to use DuckDuckGo only
TAVILY_MAX_RESULTS=5

# Sandbox — set SANDBOX_BACKEND=docker for full isolation (requires docker.sock mount)
SANDBOX_BACKEND=subprocess
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_SECONDS=30

# Worker metrics server (Prometheus scrapes this port)
WORKER_METRICS_PORT=9090

# JWT auth — generate a strong secret before deploying:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Memory layer — set MEMORY_ENABLED=true to activate Qdrant-backed semantic memory.
# When disabled (default) all memory calls are no-ops (NullMemoryStore, zero overhead).
MEMORY_ENABLED=false
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=agent_memory
EMBEDDING_MODEL=text-embedding-3-small

# ──────────────────────────────────────────────────────────────────────────
# Production-only (not used in local dev)
# These are generated automatically by scripts/gen-env.sh
# ──────────────────────────────────────────────────────────────────────────

# Domain name for the TLS certificate and nginx server_name
SERVER_NAME=

# Grafana admin login (replaces anonymous access in production)
GRAFANA_ADMIN_PASSWORD=
